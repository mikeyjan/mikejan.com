# Disable TypeScript type checking in webpack during development
# This works around false positives from webpack's TS checker with fast-check
# All actual type checking is done by Jest and tsc
TSC_COMPILE_ON_ERROR=true
DISABLE_ESLINT_PLUGIN=false
SKIP_PREFLIGHT_CHECK=true
# Disable TypeScript checking plugin entirely
DISABLE_NEW_JSX_TRANSFORM=false
